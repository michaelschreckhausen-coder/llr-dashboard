-- Check (in supabase/functions/generate/index.ts):
--
--   const { data: ent } = await supabaseClient.rpc('i_have_module', { p_module: requestedModule })
--   if (!ent) return new Response('Module not in plan', { status: 403 })
--
-- Empfehlung: dies parallel zur RLS umsetzen, NICHT als Ersatz —
-- RLS ist die letzte Schutzschicht.
