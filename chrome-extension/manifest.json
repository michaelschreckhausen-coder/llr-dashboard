{
  "manifest_version": 3,
  "name": "LinkedIn Lead Radar",
  "version": "1.0",
  "description": "Importiere LinkedIn-Profile direkt ins Lead Radar Dashboard",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://llr-dashboard.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lead Radar"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
