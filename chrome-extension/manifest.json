{
  "manifest_version": 3,
  "name": "Leadesk",
  "version": "9.0.0",
  "description": "LinkedIn-Profile mit einem Klick in Leadesk importieren",
  "permissions": ["activeTab","scripting","tabs","storage","alarms","windows","sidePanel"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://app.leadesk.de/*",
    "https://*.leadesk.de/*",
    "https://jdhajqpgfrsuoluaesjn.supabase.co/*",
    "https://www.linkedin.com/sales/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Leadesk — Lead importieren" },
  "side_panel": { "default_path": "sidepanel.html" },
  "content_scripts": [{"matches":["https://www.linkedin.com/*"],"js":["content.js"],"run_at":"document_idle"}],
  "web_accessible_resources": [{"resources":["icons/*.png"],"matches":["<all_urls>"]}],
  "content_security_policy": {"extension_pages":"script-src 'self'; object-src 'self'"}
}
