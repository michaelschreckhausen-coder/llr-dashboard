{
  "manifest_version": 3,
  "name": "Leadesk",
  "version": "4.0.0",
  "description": "LinkedIn Automation für Leadesk — Profile importieren, Vernetzungen senden, Kampagnen steuern",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://app.leadesk.de/*",
    "https://jdhajqpgfrsuoluaesjn.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Leadesk"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
