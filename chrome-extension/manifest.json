{
  "manifest_version": 3,
  "name": "Leadesk",
  "version": "9.8.0",
  "description": "LinkedIn-Profile mit einem Klick in Leadesk importieren",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "alarms",
    "windows",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.linkedin.com/sales/*",
    "https://app.leadesk.de/*",
    "https://staging.leadesk.de/*",
    "https://*.leadesk.de/*",
    "https://supabase.leadesk.de/*",
    "https://supabase-staging.leadesk.de/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://app.leadesk.de/*",
      "https://staging.leadesk.de/*",
      "https://*.leadesk.de/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Leadesk \u2014 Lead importieren",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://app.leadesk.de/*",
        "https://staging.leadesk.de/*",
        "https://*.leadesk.de/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
